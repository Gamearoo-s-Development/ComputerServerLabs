{
  "_comment": "Shipped defaults for Docker/QEMU desktop workstations. User overrides live in app data desktop-runtime.json.",
  "allowWithoutKvm": false,
  "resourceWarning": "Desktop workstations are heavier than terminal containers and may require several GB of RAM and disk.",
