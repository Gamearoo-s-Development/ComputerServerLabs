      "enabled": true,
      "image": "lscr.io/linuxserver/webtop:debian-xfce",
      "trusted": false,
      "webViewerPort": 3000,
      "accessPorts": [3000, 3001],
      "environment": {}
    },
    "kali": {
      "id": "desktop-container-kali",
      "name": "Kali Desktop Workstation",
      "provider": "desktop-container-kali",
      "osFamily": "linux",
      "enabled": true,
      "image": "sysadmin-game/kali-desktop:latest",
      "trusted": false,
      "webViewerPort": 3000,
