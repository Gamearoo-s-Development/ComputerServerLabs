{
  "name": "@sysadmin-game/app",
  "version": "1.0.1",
  "description": "Computer Server Labs desktop app — Electron lab platform with Docker workstations",
  "license": "MPL-2.0",
  "author": "Computer Server Labs Contributors",
  "homepage": "https://computerserverlabs.com",
  "type": "module",
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:app": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:linux": "node ./scripts/package-linux.mjs",
    "package:linux:release": "node ./scripts/package-linux.mjs --release",
    "package:linux:wsl": "node ../scripts/package-linux-wsl.mjs",
    "package:linux:appimage": "node ./scripts/package-linux.mjs --target=AppImage",
    "package:linux:deb": "node ./scripts/package-linux.mjs --target=deb",
    "lint": "eslint .",
    "test:lab-builder": "node --test src/renderer/pages/labBuilderFormUtils.test.js src/main/labBuilder/labTemplateVariables.test.js src/main/labBuilder/labFilesystem.test.js src/main/workstation/workstationHostInfo.test.js ../shared/workstations/providerUtils.test.js ../shared/workstations/workstationReadiness.test.js ../shared/workstations/workstationLoginMode.test.js",
    "security:audit": "npm audit --audit-level=high",
    "security:check": "npm audit --audit-level=high --omit=dev",
    "security:deps": "npm audit --audit-level=moderate",
    "rebuild:native": "node ./scripts/rebuild-native.mjs",
    "rebuild:native:force": "node ./scripts/rebuild-native.mjs --force"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "adm-zip": "0.5.17",
    "ajv": "8.20.0",
    "better-sqlite3": "12.10.0",
    "discord-rpc": "4.0.1",
    "node-pty": "1.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@sysadmin-game/shared": "*",
    "@electron/rebuild": "4.0.4",
    "@eslint/js": "^9.28.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "3.1.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "patch-package": "8.0.1",
    "postcss": "^8.5.4",
    "tailwindcss": "3.4.19",
    "vite": "6.4.2"
  }
}
