{
  "name": "sysadmin-game",
  "private": true,
  "description": "Computer Server Labs monorepo — desktop app, registry website, and shared packages",
  "license": "MPL-2.0",
  "workspaces": [
    "app",
    "website",
    "shared"
  ],
  "scripts": {
    "dev:app": "npm --workspace app run dev",
    "dev:website": "npm --workspace website run dev",
    "dev:api": "npm --workspace website run dev:api",
    "build:app": "npm --workspace app run build",
    "build:website": "npm --workspace website run build",
    "start:app": "npm --workspace app run start",
    "lint:app": "npm --workspace app run lint",
    "validate:labs": "node scripts/validate-lab-catalog.mjs",
    "test:labs": "node scripts/test-lab-catalog.mjs",
    "patch:lab-progression": "node scripts/generate-lab-catalog.mjs --progression-only",
    "postinstall": "patch-package --patch-dir app/patches && npm --workspace app run rebuild:native --if-present"
  },
  "devDependencies": {
    "patch-package": "8.0.1"
  }
}
