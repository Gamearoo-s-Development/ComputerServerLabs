{

  "name": "sysadmin-game-quizes",

  "version": "0.1.0",

  "description": "Community-made sysadmin challenge game with Docker mission sims",

  "license": "MPL-2.0",

  "author": "SysAdmin Game & Quizes Contributors",

  "type": "module",

  "main": "./out/main/main.js",

  "scripts": {

    "dev": "node ./node_modules/electron-vite/bin/electron-vite.js dev",

    "start": "node ./node_modules/electron-vite/bin/electron-vite.js preview",

    "build": "node ./node_modules/electron-vite/bin/electron-vite.js build",

    "dist": "npm run build && node ./node_modules/electron-builder/cli.js",

    "package:win": "npm run build && node ./node_modules/electron-builder/cli.js --win --x64",

    "package:linux": "npm run build && node ./node_modules/electron-builder/cli.js --linux --x64",

    "lint": "node ./node_modules/eslint/bin/eslint.js .",

    "security:audit": "npm audit --audit-level=high",

    "security:check": "npm audit --audit-level=high --omit=dev",

    "security:deps": "npm audit --audit-level=moderate",

    "postinstall": "node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3,node-pty"

  },

  "dependencies": {

    "@xterm/addon-fit": "0.11.0",

    "@xterm/addon-web-links": "0.12.0",

    "@xterm/xterm": "6.0.0",

    "adm-zip": "0.5.17",

    "ajv": "8.20.0",

    "better-sqlite3": "12.10.0",

    "discord-rpc": "4.0.1",

    "node-pty": "1.1.0",

    "react": "19.2.6",

    "react-dom": "19.2.6"

  },

  "devDependencies": {

    "@electron/rebuild": "4.0.4",

    "@eslint/js": "^9.28.0",

    "@vitejs/plugin-react": "^4.5.2",

    "autoprefixer": "^10.4.21",

    "electron": "36.4.0",

    "electron-builder": "26.8.1",

    "electron-vite": "3.1.0",

    "eslint": "9.39.4",

    "eslint-plugin-react": "^7.37.5",

    "eslint-plugin-react-hooks": "^5.2.0",

    "globals": "^16.2.0",

    "postcss": "^8.5.4",

    "tailwindcss": "3.4.19",

    "vite": "6.4.2"

  }

}


