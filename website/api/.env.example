# Computer Server Labs Registry API — copy to .env and adjust for your deployment.
# NEVER commit real secrets.

# Server
PORT=8787
HOST=127.0.0.1
NODE_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:8787
WEBSITE_BASE_URL=http://127.0.0.1:5174

# Shown on website homepage (GitHub Releases URL)
DESKTOP_DOWNLOAD_URL=https://github.com/your-org/your-repo/releases

# Database (SQLite path relative to server/ or absolute)
DATABASE_PATH=./data/registry.db

# Lab pack storage
LAB_PACKS_DIR=./data/lab-packs

# JWT signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL_SEC=3600
JWT_REFRESH_TTL_SEC=2592000

# Lab signing key for verified manifests (Ed25519 PEM or hex seed)
# Generate: node -e "const c=require('crypto');const {publicKey,privateKey}=c.generateKeyPairSync('ed25519');console.log('LAB_SIGNING_PRIVATE='+privateKey.export({type:'pkcs8',format:'pem'}).toString().replace(/\n/g,'\\n'))"
LAB_SIGNING_PRIVATE_KEY=
LAB_SIGNING_PUBLIC_KEY=

# Email (server-side ONLY — desktop app never receives these)
# Hostinger Email (recommended): https://www.hostinger.com/tutorials/how-to-get-email-account-configuration-details
#   SMTP_HOST=smtp.hostinger.com
#   Port 465 (SSL): SMTP_PORT=465, SMTP_SECURE=true
#   Port 587 (STARTTLS): SMTP_PORT=587, SMTP_SECURE=false (or omit SMTP_SECURE)
#   SMTP_USER = full mailbox address (e.g. noreply@yourdomain.com)
#   SMTP_PASS = mailbox password from hPanel (same as webmail login)
#   Per-type From (create mailboxes/aliases in hPanel): verify@, notifications@, noreply@
# If auth fails with smtp.hostinger.com, some Titan-backed mailboxes use SMTP_HOST=smtp.titan.email instead.
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_VERIFY=verify@yourdomain.com
EMAIL_FROM_NOTIFICATIONS=notifications@yourdomain.com
EMAIL_FROM_NOREPLY=noreply@yourdomain.com
EMAIL_FROM_NAME=Computer Server Labs
EMAIL_REPLY_TO=support@yourdomain.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=
RESEND_API_KEY=
SENDGRID_API_KEY=

# Rate limits (requests per minute)
RATE_LIMIT_GLOBAL=120
RATE_LIMIT_AUTH=20

# Admin bootstrap (optional — first admin user email after register)
ADMIN_EMAIL=
