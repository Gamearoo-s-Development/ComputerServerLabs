# Website Docker stack — copy to .env.docker in this folder:
#   cp .env.docker.example .env.docker
#
# Start (from website/ — do not pass --env-file; see docker-compose.yml):
#   docker compose up --build
#
# Local development (default below):
WEB_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
WEBSITE_BASE_URL=http://localhost:8080
#
# Production (https://computerserverlabs.com — site and /api on same origin):
# WEB_PORT=80
# PUBLIC_BASE_URL=https://computerserverlabs.com
# WEBSITE_BASE_URL=https://computerserverlabs.com

# Homepage "Download desktop app" button (GitHub Releases page recommended)
DESKTOP_DOWNLOAD_URL=https://github.com/your-org/your-repo/releases

# MariaDB (runs as the `db` service)
MARIADB_ROOT_PASSWORD=changeme-root
MARIADB_PASSWORD=registry

# Required — use hex only to avoid Docker $ interpolation issues, or escape $ as $$
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

ADMIN_EMAIL=

# Email — server-side only (never in the desktop app).
# Hostinger: SMTP_HOST=smtp.hostinger.com, SMTP_USER=primary mailbox, SMTP_PASS=mailbox password
# Port 465: SMTP_PORT=465 SMTP_SECURE=true  |  Port 587: SMTP_PORT=587 SMTP_SECURE=false
# Create mailboxes or aliases in hPanel for each From address; SMTP_USER is usually one primary mailbox.
# Per-message From (professional split):
#   verify@        — signup / resend verification
#   notifications@ — lab alerts, completions, milestones, security
#   noreply@       — password reset and other transactional
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_VERIFY=verify@yourdomain.com
EMAIL_FROM_NOTIFICATIONS=notifications@yourdomain.com
# Use the same mailbox Hostinger allows for SMTP_USER, or an alias you created (often no-reply@ not noreply@)
EMAIL_FROM_NOREPLY=no-reply@yourdomain.com
EMAIL_FROM_NAME=Computer Server Labs
EMAIL_REPLY_TO=support@yourdomain.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-mailbox-password

LAB_SIGNING_PRIVATE_KEY=
LAB_SIGNING_PUBLIC_KEY=
SEED_ON_START=true
