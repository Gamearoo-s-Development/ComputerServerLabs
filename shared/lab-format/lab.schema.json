      "then": { "required": ["docker"] }
    },
    {
      "if": { "properties": { "validation": { "properties": { "type": { "const": "command" } } } } },
      "then": { "properties": { "validation": { "required": ["command"] } } }
    },
    {
      "if": { "properties": { "validation": { "properties": { "type": { "const": "fileExists" } } } } },
      "then": { "properties": { "validation": { "required": ["path"] } } }
    },
