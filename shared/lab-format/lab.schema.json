{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sysadmin-game.local/schemas/lab.json",
  "title": "Computer Server Labs Lab Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "difficulty",
    "category",
    "description",
    "runtime",
    "tasks",
    "validation",
    "xpReward"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "difficulty": {
      "type": "string",
      "enum": ["Easy", "Medium", "Hard", "Expert"]
    },
    "category": { "type": "string", "minLength": 1, "maxLength": 80 },
    "bundled": {
      "type": "boolean",
      "description": "When true, lab ships with the app installer. Community/imported labs should set false."
    },
    "tags": {
      "type": "array",
      "maxItems": 24,
      "items": { "type": "string", "minLength": 1, "maxLength": 40 }
    },
    "successCriteria": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    },
    "securitySimulation": {
      "type": "boolean",
      "description": "When true, lab is a security simulation / CTF-style challenge in an isolated environment."
    },
    "securitySubcategory": {
      "type": "string",
      "enum": [
        "Enumeration",
        "Web Exploitation",
        "Privilege Escalation",
        "Password Recovery",
        "Misconfiguration",
        "CTF Challenge"
      ]
    },
    "accessMode": {
      "type": "string",
      "enum": ["provided", "discover"],
      "description": "provided = show SSH credentials; discover = hide credentials and show target services only."
    },
    "targetServices": {
      "type": "array",
      "maxItems": 12,
      "description": "User-visible target service routes for CTF labs (alias: services when entries are objects).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "port"],
        "properties": {
          "label": { "type": "string", "maxLength": 80 },
          "host": { "type": "string", "maxLength": 120 },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "purpose": { "type": "string", "enum": ["ssh", "web", "http", "https", "api", "database", "custom"] },
          "protocol": { "type": "string", "enum": ["tcp", "udp"] },
          "showToUser": { "type": "boolean" },
          "showCredentials": { "type": "boolean" },
          "hint": { "type": "string", "maxLength": 300 },
          "spoilLevel": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "flags": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "path": { "type": "string", "maxLength": 500 },
          "value": { "type": "string", "maxLength": 200 },
          "showToUser": { "type": "boolean" }
        }
      }
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "hideDirectSshCommand": { "type": "boolean" },
    "labMode": {
      "type": "string",
      "enum": ["target-only", "target-plus-workstation"],
      "description": "target-only: the lab container is the environment (no separate workstation). target-plus-workstation: Docker target accessed via a workstation jump box."
    },
    "workstation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recommended": {
          "type": "string",
          "maxLength": 80,
          "description": "Preferred workstation profile id when user preference is Auto"
        },
        "supported": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "enum": [
              "custom",
              "ubuntu-terminal",
              "debian-terminal",
              "kali-terminal",
              "windows-terminal",
              "windows-desktop",
              "desktop-container-ubuntu",
              "desktop-container-debian",
              "desktop-container-kali",
              "desktop-container-windows",
              "docker-ubuntu-terminal",
              "docker-debian-terminal",
              "vm-ubuntu",
              "vm-debian",
              "vm-windows",
              "local-terminal",
              "wsl-local-terminal"
            ]
          },
          "description": "Legacy hints for UI/recommendations — does not block VM workstations unless restrictToSupported is true"
        },
        "allowLocalTerminal": {
          "type": "boolean",
          "description": "When true, labs may offer Local Terminal Workstation (host shell, not sandboxed). Default false."
        },
        "allowWslLocalTerminal": {
          "type": "boolean",
          "description": "When true, labs may offer WSL Local Linux Terminal on Windows (real WSL distro, not sandboxed). Default false."
        },
        "preferDockerWorkstation": {
          "type": "boolean",
          "description": "When true (default), beginner/easy labs block local terminal and UI prefers Docker workstations."
        },
        "vmTemplateRequired": {
          "type": "boolean",
          "description": "When true, VM labs require a verified local template before deploy."
        },
        "requiredCapabilities": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "linux",
              "windows",
              "terminal",
              "shell",
              "desktop",
              "docker",
              "vm",
              "ssh",
              "powershell",
              "browser",
              "ssh-client",
              "security-tools",
              "linux-only",
              "docker-terminal-only"
            ]
          },
          "description": "Capabilities a workstation must provide (e.g. terminal for SSH labs, linux-only to exclude Windows desktop)"
        },
        "preferredCapabilities": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "linux",
              "windows",
              "terminal",
              "shell",
              "desktop",
              "docker",
              "vm",
              "ssh",
              "ssh-client",
              "security-tools",
              "powershell",
              "browser",
              "linux-only",
              "docker-terminal-only"
            ]
          },
          "description": "Soft preference shown in UI — does not block other workstations"
        },
        "optionalCapabilities": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": ["linux", "windows", "terminal", "desktop", "docker", "vm", "ssh"]
          },
          "description": "Alias for preferredCapabilities"
        },
        "blockedCapabilities": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "linux",
              "windows",
              "terminal",
              "shell",
              "desktop",
              "docker",
              "vm",
              "ssh",
              "powershell",
              "browser",
              "no-desktop",
              "linux-only",
              "docker-terminal-only"
            ]
          },
          "description": "Capabilities that disqualify a workstation for this lab (e.g. no-desktop blocks GUI workstations)"
        },
        "restrictToSupported": {
          "type": "boolean",
          "description": "When true, only profile ids listed in supported may be used (legacy strict mode)"
        },
        "supportedOnly": {
          "type": "boolean",
          "description": "Deprecated alias for restrictToSupported"
        },
        "required": {
          "description": "When true, lab mandates requiredProfile (or recommended as fallback)",
          "oneOf": [{ "type": "boolean" }, { "type": "string", "maxLength": 80 }]
        },
        "requiredProfile": {
          "type": "string",
          "maxLength": 80,
          "description": "Workstation profile id required for this lab when required is true"
        },
        "reason": {
          "type": "string",
          "maxLength": 500,
          "description": "Shown in UI when explaining workstation selection"
        },
        "recommendedWorkstation": {
          "type": "string",
          "maxLength": 80,
          "description": "Deprecated — use workstation.recommended"
        },
        "supportedWorkstations": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "maxLength": 80 },
          "description": "Deprecated — use workstation.supported"
        },
        "custom": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "id": { "type": "string", "maxLength": 80 },
            "name": { "type": "string", "maxLength": 120 },
            "description": { "type": "string", "maxLength": 500 },
            "baseImage": { "type": "string", "maxLength": 200 },
            "baseImageId": { "type": "string", "maxLength": 80 },
            "sourceType": { "type": "string", "enum": ["generated", "manual"] },
            "runtime": { "type": "string", "enum": ["linux", "windows"] },
            "packages": {
              "type": "array",
              "maxItems": 64,
              "items": { "type": "string", "maxLength": 80 }
            },
            "files": {
              "type": "array",
              "maxItems": 128,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "maxLength": 500 },
                  "content": { "type": "string", "maxLength": 65536 },
                  "owner": { "type": "string", "maxLength": 64 },
                  "group": { "type": "string", "maxLength": 64 },
                  "mode": { "type": "string", "pattern": "^0[0-7]{3}$" },
                  "stage": { "type": "string", "enum": ["build", "runtime"] }
                }
              }
            },
            "directories": {
              "type": "array",
              "maxItems": 64,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "maxLength": 500 },
                  "owner": { "type": "string", "maxLength": 64 },
                  "group": { "type": "string", "maxLength": 64 },
                  "mode": { "type": "string", "pattern": "^0[0-7]{3}$" },
                  "stage": { "type": "string", "enum": ["build", "runtime"] }
                }
              }
            },
            "environment": {
              "type": "object",
              "additionalProperties": { "type": "string", "maxLength": 500 }
            },
            "startupMessage": { "type": "string", "maxLength": 2000 }
          }
        }
      }
    },
    "estimatedTimeMinutes": { "type": "integer", "minimum": 1, "maximum": 10080 },
    "runtime": {
      "type": "string",
      "enum": ["docker"],
      "description": "Docker-only labs (Linux or Windows containers)."
    },
    "docker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "type": "string", "minLength": 1, "maxLength": 200 },
        "imageSource": {
          "type": "string",
          "enum": ["local-build", "prebuilt"],
          "description": "local-build = build from Dockerfile in buildPath; prebuilt = pull image from registry"
        },
        "buildPath": { "type": "string", "maxLength": 120 },
        "ports": {
          "type": "array",
          "minItems": 0,
          "maxItems": 8,
          "description": "Empty array is valid for target-only labs (integrated terminal, no host-published ports).",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "anyOf": [{ "required": ["container"] }, { "required": ["containerPort"] }],
            "properties": {
              "container": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["tcp", "udp"] },
              "purpose": {
                "type": "string",
                "enum": ["ssh", "web", "http", "https", "api", "database", "custom"],
                "description": "Service purpose for routing and UI"
              },
              "label": { "type": "string", "maxLength": 80 },
              "exposeToHost": {
                "type": "boolean",
                "description": "When true, publish to 127.0.0.1 on a random host port"
              },
              "showToUser": {
                "type": "boolean",
                "description": "When true, list in Available Lab Services UI"
              },
              "showCredentials": {
                "type": "boolean",
                "description": "When false, service route is shown without credentials (CTF / discover mode)."
              },
              "hint": { "type": "string", "maxLength": 300 },
              "spoilLevel": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "host": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535,
                "description": "Optional locked host port (Developer Mode only at runtime)"
              },
              "bindAll": {
                "type": "boolean",
                "description": "When true and Developer Mode is on, may bind 0.0.0.0 instead of 127.0.0.1"
              }
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string", "maxLength": 500 }
        },
        "baseImage": { "type": "string", "maxLength": 200 },
        "baseImageId": { "type": "string", "maxLength": 80 },
        "builderGenerated": {
          "type": "boolean",
          "description": "When true, Lab Builder generates Dockerfile/entrypoint from builder fields"
        },
        "packages": {
          "type": "array",
          "maxItems": 64,
          "items": { "type": "string", "maxLength": 80 }
        },
        "services": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "enum": ["ssh", "nginx", "apache", "cron", "python-http"]
          }
        },
        "startupCommands": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command"],
            "properties": {
              "command": { "type": "string", "maxLength": 2000 },
              "label": { "type": "string", "maxLength": 120 },
              "runAs": { "type": "string", "enum": ["root", "lab-user"] },
              "when": { "type": "string", "enum": ["before-ssh", "after-files"] }
            }
          }
        }
      }
    },
    "files": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "maxLength": 500 },
          "content": { "type": "string", "maxLength": 65536 },
          "owner": { "type": "string", "maxLength": 64 },
          "group": { "type": "string", "maxLength": 64 },
          "mode": { "type": "string", "pattern": "^0[0-7]{3}$" },
          "stage": { "type": "string", "enum": ["build", "runtime"] }
        }
      }
    },
    "directories": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "maxLength": 500 },
          "owner": { "type": "string", "maxLength": 64 },
          "group": { "type": "string", "maxLength": 64 },
          "mode": { "type": "string", "pattern": "^0[0-7]{3}$" },
          "stage": { "type": "string", "enum": ["build", "runtime"] }
        }
      }
    },
    "vm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["virtualbox"],
          "description": "Only Oracle VirtualBox is supported"
        },
        "guestOs": {
          "type": "string",
          "enum": ["ubuntu", "debian", "windows", "windows-server", "kali", "arch", "fedora", "unknown"]
        },
        "isoRequired": { "type": "boolean" },
        "isoMatch": {
          "type": "array",
          "maxItems": 12,
          "items": { "type": "string", "maxLength": 80 }
        },
        "memoryMb": { "type": "integer", "minimum": 512, "maximum": 32768 },
        "cpuCount": { "type": "integer", "minimum": 1, "maximum": 32 },
        "diskGb": { "type": "integer", "minimum": 10, "maximum": 512 },
        "networkMode": {
          "type": "string",
          "enum": ["nat", "host-only", "internal", "bridged"]
        },
        "setupMode": {
          "type": "string",
          "enum": ["manual", "assisted", "unattended", "autoinstall"],
          "description": "manual = user installs OS; assisted = guided steps + unattended media; unattended = automated install where supported. autoinstall is an alias for unattended."
        },
        "lifecycle": {
          "type": "string",
          "enum": ["ephemeral", "persistent", "template"],
          "description": "ephemeral = delete VM after session (default); persistent = keep VM; template = temporary clone from vm.template"
        },
        "viewer": {
          "type": "string",
          "enum": ["virtualbox", "rdp", "external"]
        },
        "template": { "type": "string", "maxLength": 120 },
        "snapshot": { "type": "string", "maxLength": 120 },
        "cpus": { "type": "integer", "minimum": 1, "maximum": 32 },
        "osType": { "type": "string", "maxLength": 80 },
        "isoPolicy": {
          "type": "string",
          "enum": ["user_provided_iso", "official_mirror_only", "no_iso_bundled"]
        },
        "viewerType": {
          "type": "string",
          "enum": ["rdp", "spice", "vnc", "external", "virtualbox"]
        },
        "setupMethod": { "type": "string", "maxLength": 120 },
        "supportedGuests": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "maxLength": 80 }
        },
        "recommendedGuest": { "type": "string", "maxLength": 80 }
      }
    },
    "vmGuestVariants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "guestOs"],
        "properties": {
          "label": { "type": "string", "maxLength": 120 },
          "description": { "type": "string", "maxLength": 500 },
          "guestOs": {
            "type": "string",
            "enum": ["ubuntu", "debian", "windows", "windows-server", "unknown"]
          },
          "vmIso": { "$ref": "#/properties/vmIso" }
        }
      }
    },
    "labGuides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "maxLength": 200 },
          "warning": { "type": "string", "maxLength": 500 },
          "steps": {
            "type": "array",
            "maxItems": 24,
            "items": { "type": "string", "maxLength": 500 }
          },
          "links": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "object",
              "required": ["label", "url"],
              "properties": {
                "label": { "type": "string", "maxLength": 120 },
                "url": { "type": "string", "maxLength": 500 }
              }
            }
          },
          "commands": {
            "type": "array",
            "maxItems": 12,
            "items": { "type": "string", "maxLength": 200 }
          }
        }
      }
    },
    "safetyNotes": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "maxLength": 500 }
    },
    "vmIso": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "recommendedType": {
          "type": "string",
          "maxLength": 80,
          "description": "e.g. ubuntu-server, ubuntu-desktop, debian, windows"
        },
        "acceptedTypes": {
          "type": "array",
          "maxItems": 12,
          "items": { "type": "string", "maxLength": 80 }
        },
        "isoMatch": {
          "type": "array",
          "maxItems": 12,
          "items": { "type": "string", "maxLength": 80 },
          "description": "Filename tokens that should appear in the chosen ISO"
        },
        "downloadLinks": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string", "maxLength": 120 },
              "url": { "type": "string", "maxLength": 500 },
              "verified": { "type": "boolean" }
            }
          }
        }
      }
    },
    "credentials": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "username": { "type": "string", "maxLength": 64 },
        "host": { "type": "string", "maxLength": 120 },
        "generatedPerSession": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["generated", "static"] },
        "usernameSource": { "type": "string", "enum": ["profile", "fixed"] },
        "passwordLength": { "type": "integer", "minimum": 8, "maximum": 128 }
      }
    },
    "objectivesPublic": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1, "maxLength": 500 },
          "text": { "type": "string", "maxLength": 500 },
          "prompt": { "type": "string", "maxLength": 1000 },
          "serviceRef": {
            "type": "string",
            "maxLength": 32,
            "description": "References a service route purpose/id (web, api, ssh, etc.)"
          },
          "hint": {
            "type": "string",
            "maxLength": 500,
            "description": "Optional nudge for this step — revealed per objective in the lab UI"
          }
        }
      }
    },
    "setupSecrets": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "enum": ["trainingFlag", "flagFilename"]
      }
    },
    "objectives": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1, "maxLength": 500 },
          "autoCheck": {
            "type": "string",
            "enum": [
              "manual",
              "fileExists",
              "command",
              "portOpen",
              "serviceRunning",
              "permission",
              "userExists",
              "packageInstalled",
              "enumeratePorts",
              "identifyService",
              "findUsername",
              "findPassword",
              "obtainSshAccess",
              "findUserFlag",
              "privilegeEscalation",
              "findRootFlag",
              "submitFlag",
              "answerQuestion"
            ]
          },
          "securityType": {
            "type": "string",
            "enum": [
              "enumeratePorts",
              "identifyService",
              "findUsername",
              "findPassword",
              "obtainSshAccess",
              "findUserFlag",
              "privilegeEscalation",
              "findRootFlag",
              "submitFlag",
              "answerQuestion"
            ]
          },
          "path": { "type": "string", "maxLength": 500 },
          "mode": { "type": "string", "pattern": "^[0-7]{3,4}$" },
          "prompt": { "type": "string", "maxLength": 1000 },
          "acceptedAnswers": {
            "type": "array",
            "maxItems": 32,
            "items": { "type": "string", "maxLength": 200 }
          },
          "answerKey": {
            "type": "string",
            "pattern": "^(trainingFlag|flagFilename|flag:[a-z0-9-]+)$"
          },
          "answerConfig": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "caseSensitive": { "type": "boolean" },
              "useRegex": { "type": "boolean" },
              "allowContains": { "type": "boolean" }
            }
          },
          "command": {
            "type": "array",
            "maxItems": 16,
            "items": { "type": "string", "maxLength": 200 }
          },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "service": { "type": "string", "maxLength": 120 },
          "package": { "type": "string", "maxLength": 120 },
          "user": { "type": "string", "maxLength": 64 },
          "hint": {
            "type": "string",
            "maxLength": 500,
            "description": "Author-only hint when not using objectivesPublic.hint"
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
